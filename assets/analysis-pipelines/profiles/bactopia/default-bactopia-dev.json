{
    "pipelineName": "bactopia/bactopia",
    "version": "dev",
    "parametersSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
            "max_cpus": {
                "type": "integer",
                "title": "max_cpus",
                "minimum": 1,
                "default": 8
            },
            "max_memory": {
                "type": "string",
                "title": "max_memory",
                "default": "24.GB"
            },
            "ont": {
                "type": "string",
                "title": "ont"
            },
            "sample": {
                "type": "string",
                "title": "sample"
            }
        },
        "required": ["sample"]
    },
    "uiSchema": {
        "type": "VerticalLayout",
        "elements": [
            { "type": "Control", "scope": "#/properties/max_cpus" },
            { "type": "Control", "scope": "#/properties/max_memory" },
            { "type": "Control", "scope": "#/properties/ont" },
            { "type": "Control", "scope": "#/properties/sample" }
        ]
    },
    "submission": {
        "optionsFieldName": "nextflowOptions",
        "encoding": "cli-string"
    }
}
